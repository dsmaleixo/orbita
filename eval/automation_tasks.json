{
  "version": "1.0",
  "description": "5 automation task definitions for Órbita evaluation",
  "tasks": [
    {
      "id": "a01",
      "name": "Categorize Current Month Transactions",
      "automation_type": "categorize",
      "input": {
        "start_date": "2026-02-01",
        "end_date": "2026-03-15"
      },
      "expected_output": {
        "has_categories": true,
        "min_categories": 2,
        "has_total_transactions": true
      },
      "success_criteria": "Transactions categorized into at least 2 categories with total count"
    },
    {
      "id": "a02",
      "name": "Detect Deviation from Emergency Fund Goal",
      "automation_type": "goal_alert",
      "input": {
        "start_date": "2026-02-01",
        "end_date": "2026-03-15",
        "goals": [
          {
            "name": "Reserva de Emergência",
            "target_amount": 30000,
            "months_remaining": 6
          }
        ]
      },
      "expected_output": {
        "has_alerts": true,
        "alert_contains": "Reserva de Emergência",
        "savings_below_target": true
      },
      "success_criteria": "Alert generated because monthly savings are below R$5000/month required for R$30k goal in 6 months"
    },
    {
      "id": "a03",
      "name": "Generate Monthly Report",
      "automation_type": "report",
      "input": {
        "start_date": "2026-02-01",
        "end_date": "2026-03-15"
      },
      "expected_output": {
        "has_period": true,
        "has_summary": true,
        "has_insights": true,
        "has_top_categories": true
      },
      "success_criteria": "Report contains period, income/expense summary, top spending categories, and at least 1 insight"
    },
    {
      "id": "a04",
      "name": "Detect Overspending Against Budget",
      "automation_type": "goal_alert",
      "input": {
        "start_date": "2026-02-01",
        "end_date": "2026-03-15",
        "goals": [
          {
            "name": "Controle de Gastos (max R$900/mes)",
            "target_amount": 900.0,
            "months_remaining": 1
          }
        ]
      },
      "expected_output": {
        "has_alerts": true,
        "alert_contains": "Controle de Gastos",
        "savings_below_target": true
      },
      "success_criteria": "Alert generated because monthly savings are below R$900 target"
    },
    {
      "id": "a05",
      "name": "Detect Low Savings Pattern",
      "automation_type": "goal_alert",
      "input": {
        "start_date": "2026-01-01",
        "end_date": "2026-03-15",
        "goals": [
          {
            "name": "Poupanca Mensal (meta: R$500/mes)",
            "target_amount": 1500.0,
            "months_remaining": 3
          }
        ]
      },
      "expected_output": {
        "has_alerts": true,
        "alert_contains": "Poupanca Mensal",
        "savings_below_target": true
      },
      "success_criteria": "Alert generated because savings are below R$500/month required for R$1500 goal in 3 months"
    }
  ]
}
