# Ollama configuration
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b

# Embedding model (HuggingFace)
EMBED_MODEL=BAAI/bge-m3
RERANKER_MODEL=BAAI/bge-reranker-v2-m3
ENABLE_RERANKER=false

# FAISS index path
FAISS_INDEX_PATH=data/faiss_index

# MCP / Pluggy configuration
MCP_ALLOWLIST_PATH=config/mcp_allowlist.yaml

# Pluggy API credentials (get at https://dashboard.pluggy.ai/)
PLUGGY_CLIENT_ID=your_pluggy_client_id_here
PLUGGY_CLIENT_SECRET=your_pluggy_client_secret_here
PLUGGY_ITEM_ID=your_pluggy_item_id_here
PLUGGY_BASE_URL=https://api.pluggy.ai

# Logging
AUDIT_LOG_PATH=logs/mcp_audit.log
LANGGRAPH_VERBOSE=0

# Safety
MAX_RETRIEVAL_ATTEMPTS=2
SELF_CHECK_THRESHOLD=0.5
